# Resend API key — used by the /contact form to send mail.
# Get a key at https://resend.com and copy it into .env.local (gitignored).
RESEND_API_KEY=

# Keystatic CMS — set on production only.
# In dev, leave PUBLIC_KEYSTATIC_STORAGE=local to read/write src/content/ directly.
# In prod, set PUBLIC_KEYSTATIC_STORAGE=github and fill in the repo + GitHub App
# credentials. The OAuth callback runs an editor allowlist check against the
# repo collaborators (admin/maintain/write only).
#
# PUBLIC_* vars are inlined into the browser bundle (Keystatic's React UI needs
# to know which storage mode to render). The CLIENT_SECRET stays server-only.
PUBLIC_KEYSTATIC_STORAGE=local
PUBLIC_KEYSTATIC_REPO_OWNER=
PUBLIC_KEYSTATIC_REPO_NAME=
# The Keystatic branch the admin lands on by default. Set to "staging" in
# the preview-scope env vars so Yilun's edits go through staging → publish
# rather than committing straight to main. Defaults to "main" when unset.
PUBLIC_KEYSTATIC_BRANCH=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Required by Keystatic when storage is "github" — used internally to sign
# OAuth state. Any 32+ byte random string works. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEYSTATIC_SECRET=

# Basic-auth password for the preview deployment (edit.yilunlab.com).
# Required only on Vercel's "Preview" scope; leave unset on Production
# so yilunlab.com remains public.
PREVIEW_PASSWORD=
