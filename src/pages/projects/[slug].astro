---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@components/BaseLayout.astro";
import CaseStudyLayout from "@components/CaseStudyLayout.astro";
import JsonLd from "@components/JsonLd.astro";
import { SITE_URL } from "@lib/data/seo";

export async function getStaticPaths() {
  const entries = await getCollection(
    "projects",
    ({ data }: CollectionEntry<"projects">) => !data.draft
  );
  entries.sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
      (a.data.order ?? 9999) - (b.data.order ?? 9999)
  );

  return entries.map((entry: CollectionEntry<"projects">, i: number) => {
    const next = entries[(i + 1) % entries.length];
    return {
      params: { slug: entry.id },
      props: { entry, next },
    };
  });
}

interface Props {
  entry: CollectionEntry<"projects">;
  next: CollectionEntry<"projects">;
}

const { entry, next } = Astro.props;
const projectUrl = `${SITE_URL}/projects/${entry.id}`;

const creativeWorkLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "@id": `${projectUrl}#work`,
  name: entry.data.title,
  description: entry.data.tagline,
  url: projectUrl,
  image: `${SITE_URL}/assets/images/projects/${entry.id}/cover.jpg`,
  dateCreated: entry.data.year,
  creator: { "@id": `${SITE_URL}/about#person` },
  keywords: entry.data.category.map(
    (c: string) => `Light & ${c[0].toUpperCase() + c.slice(1)}`
  ),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Works", item: `${SITE_URL}/#works` },
    { "@type": "ListItem", position: 3, name: entry.data.title },
  ],
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.tagline}
  canonical={`/projects/${entry.id}`}
>
  <JsonLd data={creativeWorkLd} slot="head" />
  <JsonLd data={breadcrumbLd} slot="head" />
  <CaseStudyLayout entry={entry} next={next} />
</BaseLayout>
